# =============================================================================
# Mediflow Workspace Root Environment Configuration Template
# =============================================================================
# Duplicate this file as '.env' in appropriate subdirectories (or configure
# in your deployment platform environment settings like Vercel, Railway, HF)
# and replace placeholders with real keys. Never commit real keys to Git.
# =============================================================================

# ── Supabase Setup (Required) ────────────────────────────────────────────────
# Found at: Supabase Dashboard -> Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_secret_key_here

# ── Frontend Specific Configurations (Required for UI build) ─────────────────
# Note: Vite loads environment variables starting with VITE_ to the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key_here

# FastAPI Backend URLs:
VITE_BACKEND_URL=http://localhost:8000
VITE_AI_BACKEND_URL=http://localhost:8000

# Error monitoring & Telemetry:
VITE_SENTRY_DSN=your_sentry_dsn_url_here
VITE_MIXPANEL_TOKEN=your_mixpanel_project_token_here

# Consent HMAC Verification:
VITE_CONSENT_HMAC_KEY=your_hmac_secret_key_here

# Feature flags:
VITE_USE_MOCK=false

# ── Cashfree Payment Gateway integration (Supabase Edge Functions / Backend) ──
# Vault Secrets required in Edge Functions:
CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here
CASHFREE_ENV=sandbox # Switch to "production" before going live

# ── Meta WhatsApp Cloud API (Supabase Edge Functions / Backend) ──────────────
META_ACCESS_TOKEN=your_meta_system_user_access_token_here
META_PHONE_NUMBER_ID=your_meta_phone_number_id_here
META_WABA_ID=your_meta_whatsapp_business_account_id_here
META_VERIFY_TOKEN=your_custom_webhook_verify_token_here
META_APP_SECRET=your_meta_app_secret_signature_key_here
WABA_DECRYPTION_KEY=your_whatsapp_decryption_secret_key_here

# ── Multi-LLM API Credentials (FastAPI Backend / Cloud Edge) ─────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=models/gemini-2.5-flash
GROQ_API_KEY=your_groq_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Backend CORS & Logging ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO

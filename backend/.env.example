# ── Supabase Credentials (Required) ───────────────────────────────────────────
SUPABASE_URL=https://kguupaybvbngyzyofjun.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── High-Concurrency Connection Pooling (Transaction Mode - Port 6543) ────────

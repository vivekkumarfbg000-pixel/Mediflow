# mode=transaction is recommended for high-concurrency serverless/FastAPI workloads
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.kguupaybvbngyzyofjun.supabase.co:6543/postgres?pgbouncer=true&sslmode=require
